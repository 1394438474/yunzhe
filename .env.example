# Cloudinary 配置（免费云存储服务）
# 注册地址：https://cloudinary.com/users/register/free
VITE_CLOUDINARY_CLOUD_NAME=你的CloudName
VITE_CLOUDINARY_API_KEY=你的APIKey
VITE_CLOUDINARY_API_SECRET=你的APISecret
VITE_CLOUDINARY_UPLOAD_PRESET=nexus-images

# Supabase 配置（可选，用于项目卡片功能）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
